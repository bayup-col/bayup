# Database (vacío = SQLite local; en producción usar la URL del Transaction Pooler de Supabase)
# Supabase: Settings > Database > Connection Pooling > Transaction mode > Connection string (puerto 6543)
# Ejemplo: postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Security (genera uno distinto por entorno con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_to_a_secure_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Payment Gateway (Wompi)
WOMPI_PUBLIC_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# Supabase Auth — para envío de email de confirmación al registrarse
# Obtener en: Supabase Dashboard > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# URL base del frontend (aparece en el link del email de confirmación)
SITE_URL=https://bayup.com.co
# URL pública del backend (usada por bayup.js SDK en plantillas HTML)
BACKEND_URL=https://api-bayup.onrender.com

# File uploads (Supabase Storage, S3-compatible API)
# Supabase dashboard: Project Settings > Storage > S3 Connection
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# AI Services
OPENAI_API_KEY=

# Monitoreo Sentry (opcional — dejar vacío para desactivar completamente)
# Obtener en: https://sentry.io > Settings > Projects > [proyecto] > Client Keys (DSN)
SENTRY_DSN=
# Entorno que aparece en Sentry (production | staging | development)
APP_ENV=production
